{
  "info": {
    "name": "Tabia IS",
    "description": "Collection gerada a partir do spec openapi-careos-simple.json — CareOS (Tabia Health) API.\n\nVariáveis:\n- `baseUrl`: https://app.tabia.health\n- `apiKey`: chave de acesso (api-key header)\n\nTodos os requests já incluem o header `api-key` via variável de coleção.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://app.tabia.health",
      "type": "string"
    },
    {
      "key": "apiKey",
      "value": "ea5c633a-1722-4d09-8a7d-d5e7a3fe35c2",
      "type": "string"
    }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "api-key", "type": "string" },
      { "key": "value", "value": "{{apiKey}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Patient",
      "item": [
        {
          "name": "List Patients",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/apiv1/patient?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["apiv1", "patient"],
              "query": [
                { "key": "page", "value": "0", "description": "Página (0-based)" },
                { "key": "size", "value": "10", "description": "Itens por página" },
                { "key": "search", "value": "", "description": "Busca textual (nome, telefone, etc)", "disabled": true },
                { "key": "sortBy", "value": "", "disabled": true },
                { "key": "sortDir", "value": "asc", "disabled": true },
                { "key": "inAnyPathway", "value": "true", "disabled": true },
                { "key": "smartFilter", "value": "", "disabled": true },
                { "key": "programs", "value": "", "disabled": true },
                { "key": "pathways", "value": "", "disabled": true },
                { "key": "ids", "value": "", "disabled": true },
                { "key": "tags", "value": "", "disabled": true },
                { "key": "insurances", "value": "", "disabled": true },
                { "key": "segment", "value": "", "disabled": true },
                { "key": "withPhoneNumber", "value": "true", "disabled": true },
                { "key": "start", "value": "", "disabled": true },
                { "key": "end", "value": "", "disabled": true },
                { "key": "structuredSearch", "value": "", "description": "Busca estruturada (JSON)", "disabled": true },
                { "key": "minimalInfo", "value": "false", "disabled": true }
              ]
            },
            "description": "Lista paginada de pacientes com tabiaScore, tags, planos de cuidado e seguros de saúde."
          }
        },
        {
          "name": "Get Patient by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/apiv1/patient/:id",
              "host": ["{{baseUrl}}"],
              "path": ["apiv1", "patient", ":id"],
              "variable": [
                { "key": "id", "value": "448266", "description": "ID interno Tabia do paciente" }
              ]
            },
            "description": "Retorna detalhe completo do paciente incluindo endereços, profissionais associados, ICDs, times e histórico."
          }
        },
        {
          "name": "Get Patient Data on Current Organization",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/apiv1/patient/:id/data-on-current-organization",
              "host": ["{{baseUrl}}"],
              "path": ["apiv1", "patient", ":id", "data-on-current-organization"],
              "variable": [
                { "key": "id", "value": "448266", "description": "ID interno Tabia do paciente" }
              ]
            },
            "description": "Dados do paciente específicos da organização atual (segmentação, flags etc)."
          }
        }
      ]
    },
